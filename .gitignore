# local-only test fixtures (not part of the published demo).
# The folder itself IS committed (via sample/.gitkeep) so the
# idempotency test in tests/run-tests.js has a place to read from;
# but the *.cfm fixtures inside are developer-private.
sample/*
!sample/.gitkeep
!sample/README.md

# npm — node_modules is NOT committed; the tree-sitter runtime + grammar
# the browser actually needs are vendored under vendor/tree-sitter/ instead.
# package-lock.json IS committed to pin devDependency versions.
node_modules/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Claude Code harness — transient lock/scratch files.
# .claude/launch.json IS committed (see existing tracked file); only the
# transient files inside .claude/ are ignored.
.claude/scheduled_tasks.lock
.claude/cache/
.claude/state/
